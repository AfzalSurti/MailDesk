DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ENCRYPTION_KEY=generate-with-python-secrets-token-urlsafe-32

# Comma-separated OpenRouter keys — rotation on 401/402/429
# Also accepts OPENROUTER_API_KEY
API_KEY=sk-or-v1-key1,sk-or-v1-key2,sk-or-v1-key3

# Also accepts OPENROUTER_MODEL
MODEL_NAME=openai/gpt-4o-mini

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Also accepts CLIENT_ID and CLIENT_SECRET as aliases
DEBUG=true
